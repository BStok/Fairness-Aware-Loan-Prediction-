# Dataset files — never commit raw or processed data
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Common data formats
*.csv
!data/processed/splits/X_train.csv
!data/processed/splits/X_test.csv
!data/processed/splits/Y_train.csv
!data/processed/splits/Y_test.csv
!data/processed/splits/X_val.csv
!data/processed/splits/Y_val.csv
*.xlsx
*.xls
*.parquet
*.json
*.pkl
*.joblib

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# Jupyter Notebooks
.ipynb_checkpoints/
*.nbconvert.py


# OS & IDE junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs & temporary outputs
*.log
logs/
tmp/
